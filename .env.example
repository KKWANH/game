# Supabase — get these from your Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the client. Used by service-role server actions
# to deal cards and mutate authoritative game state.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Public site URL (used for OAuth redirects). Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret for the turn-timeout cron sweep (/api/cron/sweep). Optional
# locally; set it in production and pass it as the `x-cron-secret` header.
CRON_SECRET=change-me-to-a-long-random-string
